.vscode/
.idea/
*.swp
*.swo

# Coverage reports
htmlcov/
.coverage
.coverage.*

# Compiled C extensions
*.so

# Logs
*.log

# LaTeX build artifacts (kept locally for VS Code LaTeX Workshop extension)
latex/*.aux
latex/*.fdb_latexmk
latex/*.fls
latex/*.out
latex/*.synctex.gz
latex/*.bbl
latex/*.blg
